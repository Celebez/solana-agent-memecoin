.env
.env.local
.env.*.local
*.env
config.local.yaml
secrets.yaml
helius_key.txt
rpc_url.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/
*.pid

# OS
.Trash-*
.nfs*

# Project specific
/data/
/output/
/tmp/
reports/
*.bak
